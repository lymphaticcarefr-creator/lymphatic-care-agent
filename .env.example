# ============================================================
# LYMPHATIC CARE — AGENT QUALIFICATION
# Copier ce fichier en .env et remplir les valeurs
# ============================================================

# --- OLLAMA (Mistral local) ---
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# --- BREVO ---
BREVO_API_KEY=your_brevo_api_key_here
BREVO_LIST_HOT=1
BREVO_LIST_WARM=2
BREVO_LIST_COLD=3
BREVO_LIST_DISQUALIFIED=4
BREVO_AUTOMATION_NURTURING=your_automation_id
BREVO_AUTOMATION_COLD=your_automation_id_cold
BREVO_SENDER_EMAIL=contact@lymphaticcare.fr
BREVO_SENDER_NAME=Lymphatic Care

# --- NOTION ---
NOTION_API_KEY=secret_your_notion_key
NOTION_DB_HOT=your_hot_database_id
NOTION_DB_WARM=your_warm_database_id
NOTION_DB_COLD=your_cold_database_id

# --- CALENDLY ---
CALENDLY_LINK=https://calendly.com/lymphaticcare/appel-strategique

# --- EMAILS INTERNES ---
MAIL_FRANCK=franck@lymphaticcare.fr
MAIL_EQUIPE=reseau@lymphaticcare.fr

# --- SECURITE WEBHOOK ---
WEBHOOK_SECRET=votre_secret_tres_long_ici

# --- REDIS (gestion état conversations) ---
REDIS_URL=redis://localhost:6379
CONVERSATION_TTL=172800

# --- APP ---
APP_ENV=production
LOG_LEVEL=INFO
PORT=8000
